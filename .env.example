# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# --- Supabase Edge Function Secrets ---
# Set these via: supabase secrets set KEY=value
# Or via Supabase Dashboard → Edge Functions → Secrets

# REQUIRED: Google Gemini API key (replaces LOVABLE_API_KEY)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: DeepL API key for higher-quality translations (Gemini is fallback)
# Get from: https://www.deepl.com/pro-api
DEEPL_API_KEY=your_deepl_api_key_here
